{
  "name": "fluent-stack-remotion",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "description": "Remotion video renderer for Fluent Stack Podcast",
  "main": "src/index.tsx",
  "dependencies": {
    "@remotion/bundler": "4.0.455",
    "@remotion/cli": "4.0.455",
    "@remotion/google-fonts": "4.0.0",
    "@remotion/media-utils": "4.0.0",
    "@remotion/player": "4.0.0",
    "@remotion/renderer": "4.0.455",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "openai": "^4.28.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "remotion": "4.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "17.0.20",
    "@types/react-dom": "17.0.9",
    "@vitejs/plugin-react": "^4.2.1",
    "express": "^4.18.2",
    "typescript": "4.4.2",
    "vite": "^8.0.10"
  },
  "scripts": {
    "dev:api": "npm run dev -w @fluent-stack/api",
    "dev:video": "npm run dev -w @fluent-stack/video",
    "studio": "npm run studio -w @fluent-stack/video",
    "render": "npm run render -w @fluent-stack/video",
    "render:short": "npm run render:short -w @fluent-stack/video",
    "check-types": "npm run build -w @fluent-stack/shared && npm run check-types -w @fluent-stack/api && npm run check-types -w @fluent-stack/video"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
